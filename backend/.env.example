# Copy to .env and fill in real values. The app fails to start if any are missing.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/creatorclub
# Any long random string — signs the session cookie.
SESSION_SECRET=
# Where the OAuth callback redirects after sign-in (the Vite dev server).
FRONTEND_URL=http://localhost:5173
